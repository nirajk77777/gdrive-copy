  },
  "scripts": {
    "smoke": "node bin/gdrive-copy.js --help || true",
    "prepublishOnly": "npm run smoke && npm pack --dry-run"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "googleapis": "^144.0.0",
    "open": "^10.0.0"
  }
