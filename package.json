{
  "name": "gdrive-copy",
  "version": "1.0.1",
  "description": "Copy a shared Google Drive folder to your own Google Drive",
  "author": "nirajk77777",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirajk77777/gdrive-copy.git"
  },
  "homepage": "https://github.com/nirajk77777/gdrive-copy#readme",
  "bugs": {
    "url": "https://github.com/nirajk77777/gdrive-copy/issues"
  },
  "keywords": [
    "google-drive",
    "drive",
    "copy",
    "cli",
    "backup",
    "googleapis",
    "shared-folder"
  ],
  "bin": {
    "gdrive-copy": "./bin/gdrive-copy.js"
  },
  "files": [
    "bin/",
    "lib/"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
